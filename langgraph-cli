@app.command()
def config(key: str = typer.Argument(None), value: str = typer.Argument(None),
           show: bool = typer.Option(False,"--show","-s")):
    cp = Path(".langgraph/config.json")
    if show or (key is None and value is None):
        typer.echo(cp.read_text(encoding="utf-8") if cp.exists() else "无 .langgraph/config.json")
        return
    cfg = json.loads(cp.read_text(encoding="utf-8")) if cp.exists() else {"model":"deepseek-v4-pro","provider":"claude"}
    if key and value:
        for t in [lambda v: True if v.lower()=="true" else None, lambda v: False if v.lower()=="false" else None, int, str]:
            try:
                cfg[key]=t(value)
                if cfg[key] is not None: break
            except: pass
        cp.write_text(json.dumps(cfg,indent=2,ensure_ascii=False)+"\n"); typer.echo(f"✅ {key}={cfg[key]}")
    elif key: typer.echo(json.dumps(cfg.get(key,"未设置"),ensure_ascii=False))

# ======================== pre-analyze ========================
def pre_analyze(target: Path) -> dict:
    """Scan project and detect characteristics for the 25% project-specific fill."""
    info = {
        "project_type": "unknown",
        "has_src_code": False,
        "has_test_code": False,
        "has_scripts": False,
        "scripts_count": 0,
        "has_harness": False,
        "has_api_client": False,
        "api_client_paths": [],
        "has_credentials": False,
        "credential_patterns": [],
        "has_runs_dir": False,
        "runs_size_mb": 0,
        "data_dirs": [],
        "has_node_scripts": False,
        "has_python_scripts": False,
        "has_playwright": False,
        "detected_words": [],
    }

    if not target.exists():
        return info

    # Scan for key files/directories
    src_dir = target / "src"
    tests_dir = target / "tests"
    scripts_dir = target / "scripts"
    harness_dir = target / "harness"
    runs_dir = target / "runs"

    # src/: check if has actual code files (not just CLAUDE.md)
    if src_dir.exists():
        py_files = list(src_dir.glob("*.py")) + list(src_dir.rglob("*.py"))
        if py_files:
            info["has_src_code"] = True

    # tests/: check if has actual test files
    if tests_dir.exists():
        test_files = list(tests_dir.glob("test_*.py")) + list(tests_dir.glob("*_test.py"))
        if test_files:
            info["has_test_code"] = True

    # scripts/: count and categorize
    if scripts_dir.exists():
        py_scripts = [f for f in scripts_dir.rglob("*.py") if f.name != "__init__.py" and "archive" not in f.parts]
        js_scripts = list(scripts_dir.rglob("*.js"))
        sh_scripts = list(scripts_dir.rglob("*.sh"))
        if py_scripts:
            info["has_python_scripts"] = True
        if js_scripts:
            info["has_node_scripts"] = True
        info["has_scripts"] = bool(py_scripts or js_scripts)
        info["scripts_count"] = len(py_scripts) + len(js_scripts) + len(sh_scripts)

    # API client detection
    for pattern in ["*api*client*", "*wqb_api*", "*brain_api*", "*machine_lib*"]:
        matches = list(target.rglob(pattern))
        for m in matches:
            if ".venv" not in str(m) and "__pycache__" not in str(m) and ".git" not in str(m):
                info["has_api_client"] = True
                info["api_client_paths"].append(str(m.relative_to(target)))

    # Credential detection
    for pattern in ["*credential*", "*config.env*", "*session_creds*"]:
        matches = list(target.rglob(pattern))
        for m in matches:
            if ".venv" not in str(m) and "__pycache__" not in str(m) and ".git" not in str(m):
                info["has_credentials"] = True
                info["credential_patterns"].append(str(m.relative_to(target)).split("/")[-1])

    # Playwright detection
    pw_matches = list(target.rglob("*playwright*"))
    info["has_playwright"] = any(".venv" not in str(m) and "__pycache__" not in str(m) for m in pw_matches)

    # Harness
    if harness_dir.exists():
        info["has_harness"] = True

    # Runs/data directory
    if runs_dir.exists():
        info["has_runs_dir"] = True
        try:
            import subprocess
            result = subprocess.run(["du", "-sh", str(runs_dir)], capture_output=True, text=True, timeout=5)
            size_str = result.stdout.split()[0]
            if "M" in size_str:
                info["runs_size_mb"] = int(float(size_str.replace("M","")))
            elif "G" in size_str:
                info["runs_size_mb"] = int(float(size_str.replace("G","")) * 1024)
            elif "K" in size_str:
                info["runs_size_mb"] = int(float(size_str.replace("K","")) / 1024)
        except:
            pass

    # Detect project type by keyword scanning
    type_checks = []
    for path in list(target.rglob("*.py"))[:50] + list(target.rglob("*.md"))[:10]:
        if ".venv" in str(path) or ".git" in str(path):
            continue
        try:
            content = path.read_text()
            for word in ["alpha", "sharpe", "BRAIN", "WorldQuant", "simulation", "expression",
                        "self_correlation", "fitness", "turnover", "submission"]:
                if word.lower() in content.lower() and word not in info["detected_words"]:
                    info["detected_words"].append(word)
        except:
            pass

    # Classify project type
    brain_keywords = {"alpha", "sharpe", "BRAIN", "WorldQuant", "simulation", "self_correlation", "fitness"}
    if len(set(w.lower() for w in info["detected_words"]) & brain_keywords) >= 3:
        info["project_type"] = "alpha-research"
    elif info["has_api_client"]:
        info["project_type"] = "api-service"
    elif info["has_src_code"] and info["has_test_code"]:
        info["project_type"] = "library-or-app"
    elif info["has_scripts"]:
        info["project_type"] = "script-toolkit"
    elif info["has_harness"]:
        info["project_type"] = "harness-project"

    return info


def _fill_project_section(info: dict) -> str:
    """Generate the 25% project-specific section from pre-analyze results."""
    lines = ["### 路径 B 项目专属\n"]
    if info["has_credentials"]:
        lines.append(f"- 安全扫描排除：{', '.join(info['credential_patterns'])}（已 gitignore）\n")
    if info["has_scripts"]:
        lines.append(f"- 脚本归档路径：scripts/archive/\n")
    if info["has_runs_dir"]:
        lines.append(f"- 数据产出目录：runs/（{info['runs_size_mb']}MB）\n")
    if not any([info["has_credentials"], info["has_scripts"], info["has_runs_dir"]]):
        lines.append("- 暂无专项配置\n")

    lines.append("\n### 路径 C 项目专属\n")
    if info["has_api_client"]:
        lines.append(f"- API 客户端：{', '.join(info['api_client_paths'][:3])}\n")
    if info["has_playwright"]:
        lines.append("- 已检测到 Playwright 浏览器自动化脚本\n")
    if info["has_credentials"]:
        lines.append(f"- 凭据文件模式：{', '.join(info['credential_patterns'][:3])}\n")
    if not any([info["has_api_client"], info["has_playwright"]]):
        lines.append("- 暂无专项配置\n")

    lines.append("\n### 路径 D 项目专属\n")
    if info["has_test_code"]:
        lines.append("- 测试框架：pytest（检测到 test_*.py 文件）\n")
    else:
        lines.append("- 测试框架：待配置（项目中未检测到测试文件）\n")
    lines.append("- 编码语言：Python")
    if info["has_node_scripts"]:
        lines.append(" + Node.js（Playwright 脚本）\n")
    else:
        lines.append("\n")

    lines.append("\n### 检测到的项目类型\n")
    lines.append(f"- 项目分类：{info['project_type']}\n")
    if info["detected_words"]:
        lines.append(f"- 关键领域词：{', '.join(info['detected_words'][:15])}\n")
    lines.append(f"- 脚本数量：{info['scripts_count']}\n")
    if info["has_harness"]:
        lines.append("- 检测到 harness 编排系统\n")

    return "".join(lines)


