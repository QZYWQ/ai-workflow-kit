# ======================== YAML 引擎 ========================
def render(tpl, ctx):
    def rep(m):
        k=m.group(1).strip().split("."); v=ctx
        for kk in k: v=v.get(kk,"") if isinstance(v,dict) else str(v)
        return str(v) if v is not None else ""
    return re.sub(r"\{\{(.*?)\}\}", rep, tpl)

def flatten(agents):
    f=[]
    for a in agents:
        if "parallel" in a and a["parallel"]:
            f.append(a)
            for s in a["parallel"]: s.update(_parent=a["name"],_group=a["name"]); f.append(s)
        else: f.append(a)
    return f

@app.command()
def run(workflow_file: str = typer.Argument(...),
        input_param: Optional[List[str]] = typer.Option(None,"--input","-i"),
        json_output: bool = typer.Option(False,"--json"),
        dry_run: bool = typer.Option(False,"--dry-run")):
    import yaml
    wf = yaml.safe_load(Path(workflow_file).read_text(encoding="utf-8"))
    if not wf or "workflow" not in wf: typer.echo("缺少 workflow",err=True); raise typer.Exit(1)
    wf = wf["workflow"]
    wname, entry, adef = wf.get("name","?"), wf.get("entry",""), wf.get("agents",[])
    inp = {}
    if input_param:
        for p in input_param:
            if "=" in p: k,v=p.split("=",1); inp[k]=v
    flat = flatten(adef)
    if dry_run:
        typer.echo(heading(f"工作流: {wname}"))
        for a in flat:
            pg = a.get("_group",""); pfx = f"  [并行:{pg}] " if pg else "  "
            rs = a.get("routes",[])
            typer.echo(f"{pfx}{a['name']} → {', '.join(r.get('to','?') for r in rs) if rs else '$end'}")
        return
    sf = {"_in":dict}
    for a in flat: sf[a["name"]]=str
    ST = TypedDict("W", sf)
    g = StateGraph(ST)
    def make_agent(nm,cfg):
        def fn(state):
            llm = get_llm(cfg.get("model",DEFAULT_MODEL))
            p = render(cfg["prompt"],{**state,"input":state["_in"]})
            typer.echo(f"  ▶ {nm}")
            r = llm.invoke(p)
            typer.echo(f"  ✓ {nm}")
            return {nm: extract_text(r.content)}
        return fn
    for a in flat: g.add_node(a["name"],make_agent(a["name"],a))
    g.set_entry_point(entry)
    for a in flat:
        rs = a.get("routes",[]); pg = a.get("_group")
        if not rs and not pg: g.add_edge(a["name"],END)
        elif pg:
            pdef = next((x for x in adef if x["name"]==a["_parent"]),{})
            for r in (pdef.get("routes",[{"to":END}])):
                t = r.get("to",END); g.add_edge(a["name"],END if t in ("$end","$human") else t)
        elif "parallel" in a:
            for s in a["parallel"]: g.add_edge(a["name"],s["name"])
        else:
            for r in rs:
                t = r.get("to",END)
                if t in ("$end","$human"):
                    if t=="$human": typer.echo(f"  ⏸ [{a['name']}] 人工(跳过)")
                    t = END
                g.add_edge(a["name"],t)
    try:
        c = g.compile()
        init = {"_in":inp}
        for a in flat: init[a["name"]]=""
        typer.echo(heading(f"▶ 工作流: {wname}"))
        result = c.invoke(init)
    except Exception as e:
        typer.echo(f"工作流失败: {e}",err=True); raise typer.Exit(1)
    if json_output:
        od = {"workflow":wname,"inputs":inp,"results":{}}
        for a in flat:
            if result.get(a["name"],""): od["results"][a["name"]]=str(result[a["name"]])[:2000]
        typer.echo(make_json(od))
    else:
        typer.echo(heading(f"✅ 完成: {wname}"))
        for a in flat:
            if result.get(a["name"],""):
                pg = a.get("_group",""); tag = f" [并行:{pg}]" if pg else ""
                typer.echo(heading(f"[{a['name']}]{tag}")); typer.echo(str(result[a["name"]])[:1500])

# ======================== 记忆 ========================
def mem_dir(cwd=None):
    for p in [Path(cwd or os.getcwd())] + list(Path(cwd or os.getcwd()).parents):
        d = p/".langgraph"
        if d.is_dir(): return d/"memory"
    return Path(cwd or os.getcwd())/".langgraph"/"memory"

@app.command()
def remember(content: str = typer.Argument(...),
             tags: Optional[str] = typer.Option(None,"--tag","-t")):
    md = mem_dir(); md.mkdir(parents=True, exist_ok=True)
    ts = datetime.now().strftime("%Y%m%d_%H%M%S")
    tl = [t.strip() for t in tags.split(",")] if tags else []
    fn = f"{ts}_{content[:60].replace(' ','_').replace('/','_')}.md"
    (md/fn).write_text(f"# {content}\n\n时间: {datetime.now().isoformat()}\n标签: {', '.join(tl) if tl else '无'}\n\n{content}\n")
    typer.echo(f"✅ 已记: {content[:80]}")

@app.command()
def recall(query: str = typer.Argument(...)):
    md = mem_dir()
    if not md.is_dir(): typer.echo("暂无记忆"); return
    rs = []
    for f in sorted(md.glob("*.md"), reverse=True):
        t = f.read_text(encoding="utf-8")
        if query.lower() in t.lower():
            ls = t.strip().split("\n"); title = ls[0].lstrip("# ").strip() if ls else ""
            cd = [l for l in ls if l.startswith("时间:")]; tg = [l for l in ls if l.startswith("标签:")]
            rs.append({"title":title,"time":cd[0] if cd else "","tags":tg[0] if tg else ""})
    if not rs: typer.echo(f"未找到「{query}」"); return
    typer.echo(f"找到 {len(rs)} 条:\n")
    for r in rs:
        typer.echo(f"  📌 {r['title']}")
        if r['tags']: typer.echo(f"     {r['tags']}")
        typer.echo(f"     {r['time']}\n")


