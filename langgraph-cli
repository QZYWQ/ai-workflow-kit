@app.command()
def config(key: str = typer.Argument(None), value: str = typer.Argument(None),
           show: bool = typer.Option(False,"--show","-s")):
    cp = Path(".langgraph/config.json")
    if show or (key is None and value is None):
        typer.echo(cp.read_text(encoding="utf-8") if cp.exists() else "无 .langgraph/config.json")
        return
    cfg = json.loads(cp.read_text(encoding="utf-8")) if cp.exists() else {"model":"deepseek-v4-pro","provider":"claude"}
    if key and value:
        for t in [lambda v: True if v.lower()=="true" else None, lambda v: False if v.lower()=="false" else None, int, str]:
            try:
                cfg[key]=t(value)
                if cfg[key] is not None: break
            except: pass
        cp.write_text(json.dumps(cfg,indent=2,ensure_ascii=False)+"\n"); typer.echo(f"✅ {key}={cfg[key]}")
    elif key: typer.echo(json.dumps(cfg.get(key,"未设置"),ensure_ascii=False))

