import os, sys, json, re, subprocess
from pathlib import Path
from typing import Optional, List, Dict, Any
from datetime import datetime

import typer
from langgraph.graph import StateGraph, START, END
from typing_extensions import TypedDict
from langchain_anthropic import ChatAnthropic

# ======================== 配置 ========================
DEFAULT_MODEL = "deepseek-v4-pro"
CONFIG_FILE = Path.home() / ".config" / "langgraph-cli" / "config.json"

os.environ.setdefault("ANTHROPIC_BASE_URL", "https://api.deepseek.com/anthropic")
os.environ.setdefault("ANTHROPIC_API_KEY",
    os.environ.get("ANTHROPIC_API_KEY") or os.environ.get("ANTHROPIC_AUTH_TOKEN", ""))

def load_project_config(cwd=None):
    for p in [Path(cwd or os.getcwd())] + list(Path(cwd or os.getcwd()).parents):
        cfg = p / ".langgraph" / "config.json"
        if cfg.exists():
            try: return json.loads(cfg.read_text(encoding="utf-8"))
            except: pass
    return {}

def get_config(cwd=None):
    cfg = {}
    if CONFIG_FILE.exists():
        try: cfg = json.loads(CONFIG_FILE.read_text(encoding="utf-8"))
        except: pass
    cfg.update(load_project_config(cwd))
    return cfg

def get_model(cwd=None):
    return get_config(cwd).get("model", DEFAULT_MODEL)

app = typer.Typer(help="多智能体开发助手")

# ======================== 工具 ========================
def get_llm(model=None, temp=0):
    return ChatAnthropic(model=(model or get_model()), temperature=temp)

def extract_text(content):
    if isinstance(content, str): return content
    texts = [b.get("text","") for b in (content if isinstance(content,list) else [])
             if isinstance(b,dict) and b.get("type")=="text"]
    return "\n".join(texts) if texts else str(content)

def read_file_or_arg(arg):
    p = Path(arg)
    return p.read_text().strip() if p.exists() and p.is_file() else arg

def make_json(data): return json.dumps(data, ensure_ascii=False, indent=2)

def heading(text): return f"\n{'='*60}\n{text}\n{'='*60}"

def git(*args):
    try:
        return subprocess.run(["git"]+list(args), capture_output=True, text=True, timeout=30).stdout.strip()
    except: return ""

def code_blocks(text):
    return re.findall(r"```(?:\w+)?\n(.*?)```", text, re.DOTALL)

# ======================== 命令 ========================
@app.command()
def ask(question: str = typer.Argument(...),
        model: str = typer.Option(get_model(), "--model","-m"),
        json_output: bool = typer.Option(False, "--json")):
    r = get_llm(model).invoke(question)
    text = extract_text(r.content)
    typer.echo(make_json({"q":question,"a":text}) if json_output else text)

@app.command()
def review(code: str = typer.Argument(...),
           output: Optional[str] = typer.Option(None,"-o"),
           json_output: bool = typer.Option(False, "--json")):
    code = read_file_or_arg(code); llm = get_llm()
    class S(TypedDict): code:str; security:str; quality:str; report:str
    def sec(s): return {"security":extract_text(llm.invoke(f"安全审查：\n```\n{s['code']}\n```").content)}
    def qual(s): return {"quality":extract_text(llm.invoke(f"质量审查：\n```\n{s['code']}\n```").content)}
    def syn(s): return {"report":extract_text(llm.invoke(f"综合P0/P1/P2：\n安全:{s['security']}\n质量:{s['quality']}").content)}
    g = StateGraph(S); g.add_node("s",sec); g.add_node("q",qual); g.add_node("y",syn)
    g.add_edge(START,"s"); g.add_edge(START,"q"); g.add_edge("s","y"); g.add_edge("q","y"); g.add_edge("y",END)
    r = g.compile().invoke({"code":code})
    if json_output: typer.echo(make_json(r))
    elif output: Path(output).write_text(r["report"]); typer.echo(f"→ {output}")
    else:
        for k in ["security","quality","report"]: typer.echo(heading(k)+"\n"+r.get(k,""))

@app.command()
def test(code: str = typer.Argument(...),
         framework: str = typer.Option("pytest","--framework","-f"),
         output: Optional[str] = typer.Option(None,"-o"),
         json_output: bool = typer.Option(False, "--json")):
    code = read_file_or_arg(code); llm = get_llm()
    plan = extract_text(llm.invoke(f"列出需测试的函数：\n```\n{code}\n```").content)
    tests = extract_text(llm.invoke(f"用{framework}写测试：\n代码:\n```\n{code}\n```\n计划:\n{plan}").content)
    if json_output: typer.echo(make_json({"plan":plan,"tests":tests}))
    elif output:
        b = code_blocks(tests); Path(output).write_text("\n\n".join(b) if b else tests)
        typer.echo(f"→ {output}")
    else: typer.echo(tests)

