@app.command()
def pr(base: str = typer.Option("main","--base","-b"),
       output: Optional[str] = typer.Option(None,"-o"),
       json_output: bool = typer.Option(False,"--json")):
    diff = git("diff",f"{base}...HEAD"); log = git("log",f"{base}...HEAD","--oneline")
    branch = git("rev-parse","--abbrev-ref","HEAD")
    if not diff: typer.echo("diff 为空",err=True); raise typer.Exit(1)
    text = extract_text(get_llm().invoke(
        f"生成PR描述：\n分支:{branch}\n提交:\n{log}\n变更:\n{diff[:6000]}").content)
    if json_output: typer.echo(make_json({"pr":text}))
    elif output: Path(output).write_text(text); typer.echo(f"→ {output}")
    else: typer.echo(text)

@app.command()
def analyze(path: str = typer.Argument("."), depth: int = typer.Option(3,"-d"),
            json_output: bool = typer.Option(False,"--json")):
    root = Path(path).resolve()
    exts = {".py",".js",".ts",".jsx",".tsx",".go",".rs",".sh",".yaml",".sql"}
    files = []
    for p in root.rglob("*"):
        if p.is_file() and p.suffix in exts:
            rel = p.relative_to(root)
            if not any(x in rel.parts for x in [".git","node_modules","__pycache__",".venv"]):
                try: files.append(str(rel))
                except: pass
    if not files: typer.echo("无源文件",err=True); raise typer.Exit(1)
    s = f"项目:{root.name}\n文件:{len(files)}\n"+"\n".join(f"  {f}" for f in files[:60])
    arch = extract_text(get_llm().invoke(f"分析项目架构：\n{s}").content)
    if json_output: typer.echo(make_json({"project":root.name,"files":len(files),"arch":arch}))
    else: typer.echo(heading(f"分析: {root.name}")+f"\n{len(files)}文件\n"+arch)

# ======================== GitNexus ========================
GNX_PATH = None
def _gnx():
    global GNX_PATH
    if GNX_PATH is not None: return GNX_PATH or None
    for d in os.environ.get("PATH","").split(":"):
        c = Path(d)/"gitnexus"
        if c.exists(): GNX_PATH=str(c); return str(c)
    for nd in (Path.home()/".nvm/versions/node").glob("*/bin/gitnexus"):
        GNX_PATH=str(nd); return str(nd)
    GNX_PATH=""; return None
def gnx_ok(): return bool(_gnx())
def gnx_call(args, cwd=None):
    e = _gnx()
    if not e: return {"error":"gitnexus not found"}
    try:
        r = subprocess.run([e]+args, capture_output=True, text=True, timeout=60, cwd=cwd)
        if r.returncode: return {"error":r.stderr.strip()}
        js=r.stdout.find("{"); return json.loads(r.stdout[js:]) if js>=0 else {"output":r.stdout.strip()}
    except json.JSONDecodeError: return {"error":"JSON parse"}
    except subprocess.TimeoutExpired: return {"error":"timeout"}
    except Exception as x: return {"error":str(x)}
def gnx_repo(cwd=None):
    return git("rev-parse","--show-toplevel") or (cwd or os.getcwd())

@app.command()
def context(symbol: str = typer.Argument(...),
            repo: Optional[str] = typer.Option(None,"--repo","-r"),
            json_output: bool = typer.Option(False,"--json")):
    if not gnx_ok(): typer.echo("GitNexus 未安装",err=True); raise typer.Exit(1)
    r = json.loads(gnx_call(["context",symbol], repo or gnx_repo()).get("output","{}")) \
        if "error" not in (d:=gnx_call(["context",symbol], (repo or gnx_repo()))) else d
    if json_output or "error" in r: typer.echo(make_json(r) if not isinstance(r,str) else r)
    else:
        sym = r.get("symbol",{})
        typer.echo(heading(f"符号: {symbol}")+f"\n类型:{sym.get('kind','?')} | 文件:{sym.get('filePath','?')} | 行:{sym.get('startLine','?')}")
        for k,v in r.get("incoming",{}).items():
            if v: typer.echo(f"\n引用者:")
            for i in v[:8]: typer.echo(f"  {i.get('filePath',i.get('name',str(i)))}")
        for k,v in r.get("outgoing",{}).items():
            if v: typer.echo(f"\n关联({k}):")
            for i in v[:8]: typer.echo(f"  {i.get('name',str(i))}")

